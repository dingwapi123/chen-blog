{
  "name": "chen-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev:blog": "pnpm --filter @chen-blog/blog-web dev",
    "dev:cms": "pnpm --filter @chen-blog/cms-admin dev",
    "lint": "eslint .",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "db:link": "supabase link --project-ref bpmmrasmlzgoalklakpn",
    "db:push": "supabase db push --linked",
    "db:seed": "supabase db push --linked --include-seed",
    "db:test": "node scripts/run-remote-database-tests.mjs",
    "db:types": "node scripts/generate-database-types.mjs"
  },
  "devDependencies": {
    "eslint": "^10.0.0",
    "supabase": "2.109.1"
  }
}
