# Shared Supabase configuration. Publishable values may be used by browser apps.
NUXT_PUBLIC_SUPABASE_URL=
NUXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_BLOG_URL=http://localhost:3000

# Nuxt server-only configuration. Never expose this key to the CMS or browser bundle.
NUXT_SUPABASE_SERVICE_ROLE_KEY=
NUXT_CMS_ORIGIN=http://localhost:5173
