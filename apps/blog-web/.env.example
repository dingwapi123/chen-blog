# Browser-visible values.
NUXT_PUBLIC_SITE_URL=http://localhost:3000
NUXT_PUBLIC_SUPABASE_URL=

# Nuxt server-only values. The publishable key still relies on RLS; keeping it
# private prevents the public blog bundle from coupling itself to the Data API.
NUXT_SUPABASE_PUBLISHABLE_KEY=
NUXT_SUPABASE_SERVICE_ROLE_KEY=
NUXT_CMS_ORIGIN=http://localhost:5173
